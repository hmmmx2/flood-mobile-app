# Flood mobile app — copy to `.env` (or EAS secrets).
#
# ── Direct Spring (no Kong) ─────────────────────────────────────────────────
# Physical device on LAN: http://<YOUR_PC_LAN_IP>:4001
# Android emulator → host: http://10.0.2.2:4001
# iOS simulator: http://localhost:4001
#
EXPO_PUBLIC_AUTH_API_URL=http://localhost:4001
# EXPO_PUBLIC_API_BASE_URL is deprecated — use EXPO_PUBLIC_AUTH_API_URL instead
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4001
EXPO_PUBLIC_CRM_API_URL=http://localhost:4002
#
# ── Via Kong gateway (deploy/docker-compose.yml, proxy port 8080) ──────────
# Replace <LAN-IP> with your machine's LAN IP for physical device testing
# with the Kong Docker stack.
# EXPO_PUBLIC_AUTH_API_URL=http://<LAN-IP>:8080/community
# EXPO_PUBLIC_CRM_API_URL=http://<LAN-IP>:8080/crm
#

EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# ── AI Prediction Service ───────────────────────────────────────────────────
EXPO_PUBLIC_AI_API_URL=http://localhost:8000
