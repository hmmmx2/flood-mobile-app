# Flood mobile app — copy to `.env` and fill in your values.
#
# ── Production (Railway) ─────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=https://flood-service-community-production.up.railway.app
EXPO_PUBLIC_AUTH_API_URL=https://flood-service-community-production.up.railway.app
EXPO_PUBLIC_CRM_API_URL=https://flood-service-crm-production.up.railway.app
EXPO_PUBLIC_AI_API_URL=https://flood-ai-prediction-production.up.railway.app

# ── Google Maps API key ───────────────────────────────────────────────────────
# Restrict to Android + package: com.floodcommunity.app
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# ── Override only when running Spring services locally ───────────────────────
# iOS simulator:     localhost
# Android emulator:  10.0.2.2  (special host alias)
# Physical device:   <your dev machine LAN IP>, e.g. 192.168.0.35
#
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4001
# EXPO_PUBLIC_AUTH_API_URL=http://10.0.2.2:4001
# EXPO_PUBLIC_CRM_API_URL=http://10.0.2.2:4002
# EXPO_PUBLIC_AI_API_URL=http://10.0.2.2:8000
