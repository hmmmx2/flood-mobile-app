# Flood mobile app — copy to `.env` only when overriding defaults.
#
# ── Default (recommended): leave API URLs unset ─────────────────────────────
# The app will automatically use the hosted Railway backend:
#   AUTH: https://flood-service-community.up.railway.app
#   CRM:  https://flood-service-crm.up.railway.app
#
# ── Override only when running Spring services locally ───────────────────────
# Pick the hostname for your run mode:
#   iOS simulator:     localhost
#   Android emulator:  10.0.2.2  (special host alias)
#   Physical device:   <your dev machine LAN IP>, e.g. 192.168.1.42
#
# EXPO_PUBLIC_AUTH_API_URL=http://10.0.2.2:4001
# EXPO_PUBLIC_CRM_API_URL=http://10.0.2.2:4002
#
# ── Kong gateway variant (deploy/docker-compose.yml, port 8080) ─────────────
# EXPO_PUBLIC_AUTH_API_URL=http://<LAN-IP>:8080/community
# EXPO_PUBLIC_CRM_API_URL=http://<LAN-IP>:8080/crm
#

EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# ── AI Prediction Service (defaults to Railway when unset) ───────────────────
# EXPO_PUBLIC_AI_API_URL=http://localhost:8000
