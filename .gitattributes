# Force LF line endings in the repository so files arrive at EAS Linux
# servers with the correct endings (CRLF breaks .easignore patterns and
# shell scripts on Linux because bash reads \r as part of the command).
* text=auto

# Shell scripts must always be LF
*.sh text eol=lf

# Config/ignore files must be LF so Linux tools parse them correctly
.easignore text eol=lf
.gitignore text eol=lf
.env* text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# Binary files — never touch line endings
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.apk binary
*.aab binary
*.ipa binary
*.keystore binary
