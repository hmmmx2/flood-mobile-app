# E2E Test Environment Variables
# Copy this file to .env.test and fill in the actual values.
# NEVER commit .env.test to version control.

# ── Test user credentials ─────────────────────────────────────────────────────
E2E_USER_EMAIL=testuser@floodwatch.test
E2E_USER_PASSWORD=TestPass123!

E2E_ADMIN_EMAIL=admin@floodwatch.test
E2E_ADMIN_PASSWORD=AdminPass123!

E2E_USER2_EMAIL=testuser2@floodwatch.test
E2E_USER2_PASSWORD=TestPass123!

# ── Android device / emulator ─────────────────────────────────────────────────
ANDROID_DEVICE=emulator-5554
ANDROID_VERSION=14.0

# ── iOS simulator (only needed for iOS run) ───────────────────────────────────
IOS_DEVICE=iPhone 15
IOS_VERSION=17.2
IOS_APP_PATH=/path/to/FloodWatch.app

# ── APK path override (default: ../android/app/build/outputs/apk/release/app-release.apk)
# APK_PATH=/custom/path/to/app-release.apk

# ── Test data references ──────────────────────────────────────────────────────
E2E_TEST_GROUP_SLUG=flood-kl
E2E_TEST_NODE_ID=NODE-001
E2E_TEST_BLOG_TITLE=Flood Safety
E2E_TEST_POST_ID=your-test-post-id-here

# ── Forgot-password OTP (retrieve from MailHog or test API in CI) ─────────────
# E2E_RESET_CODE=123456
