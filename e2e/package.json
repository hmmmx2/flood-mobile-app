{
  "name": "floodwatch-mobile-e2e",
  "version": "1.0.0",
  "description": "Appium + WebdriverIO E2E test suite for FloodWatch Community Mobile App",
  "private": true,
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:ios": "wdio run wdio.conf.ios.ts",
    "test:auth": "wdio run wdio.conf.ts --spec src/specs/auth",
    "test:feed": "wdio run wdio.conf.ts --spec src/specs/feed",
    "test:community": "wdio run wdio.conf.ts --spec src/specs/community",
    "test:blog": "wdio run wdio.conf.ts --spec src/specs/blog",
    "test:sensors": "wdio run wdio.conf.ts --spec src/specs/sensors",
    "test:alerts": "wdio run wdio.conf.ts --spec src/specs/alerts",
    "test:navigation": "wdio run wdio.conf.ts --spec src/specs/navigation",
    "test:profile": "wdio run wdio.conf.ts --spec src/specs/profile",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "appium": "appium --port 4723 --log-level info",
    "appium:install-driver": "appium driver install uiautomator2"
  },
  "devDependencies": {
    "@wdio/cli": "^8.39.0",
    "@wdio/local-runner": "^8.39.0",
    "@wdio/mocha-framework": "^8.39.0",
    "@wdio/spec-reporter": "^8.39.0",
    "@wdio/allure-reporter": "^8.39.0",
    "@wdio/appium-service": "^8.39.0",
    "appium": "^2.11.0",
    "appium-uiautomator2-driver": "^3.7.0",
    "appium-xcuitest-driver": "^7.0.0",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/mocha": "^10.0.6",
    "allure-commandline": "^2.30.0",
    "dotenv": "^16.4.5"
  }
}
