{
  "name": "flood-mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "mock": "cross-env EXPO_PUBLIC_API_MOCKING=enabled expo start --dev-client --lan",
    "postinstall": "node scripts/ensure-debug-keystore.js",
    "build:dev-cloud": "eas build --profile dev-cloud --platform android",
    "build:dev-cloud:ios": "eas build --profile dev-cloud --platform ios",
    "build:dev-cloud:all": "eas build --profile dev-cloud --platform all",
    "build:preview": "eas build --profile preview --platform android",
    "build:staging": "eas build --profile staging --platform android",
    "build:staging:ios": "eas build --profile staging --platform ios",
    "build:production": "eas build --profile production --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:apk": "eas build --profile preview --platform android",
    "wdio": "wdio run ./wdio.conf.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.83.0",
    "axios": "^1.12.2",
    "expo": "~55.0.17",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.14",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.14",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "^1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@wdio/appium-service": "^9.27.1",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "appium": "^3.3.1",
    "appium-uiautomator2-driver": "^7.2.0",
    "appium-xcuitest-driver": "^11.2.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~55.0.0",
    "expect-webdriverio": "^5.6.5",
    "expo-dev-client": "~55.0.28",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.15",
    "typescript": "~5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "<rootDir>/e2e/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@api/(.*)$": "<rootDir>/src/api/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@store/(.*)$": "<rootDir>/src/store/$1",
      "^@types/(.*)$": "<rootDir>/src/types/$1"
    }
  },
  "private": true,
  "overrides": {
    "react-native-worklets": "0.7.4"
  },
  "expo": {
    "install": {
      "exclude": []
    }
  }
}
