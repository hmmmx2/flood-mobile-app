# ─────────────────────────────────────────────────────────────────────────────
# .easignore — files excluded from EAS Cloud builds
#
# EAS Build uploads only what it needs to compile the app.
# Excluding test files, docs, and local scripts speeds up upload and avoids
# accidentally leaking sensitive local dev files.
# ─────────────────────────────────────────────────────────────────────────────

# Local environment file (secrets must be set as EAS Secrets instead)
.env

# node_modules — EAS installs dependencies fresh on the build server
node_modules/

# Android native directory — exclude everything EXCEPT gradle-wrapper.jar.
# expo prebuild on EAS says "reusing /android" (workspace persists between builds).
# gradle-wrapper.jar MUST be present or gradlew fails with "Unable to access jarfile".
# All other android/ files are regenerated by expo prebuild; only the JAR is needed.
android/**
!android/gradle/
!android/gradle/wrapper/
!android/gradle/wrapper/gradle-wrapper.jar
!android/gradle/wrapper/gradle-wrapper.properties

# Test files
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docs / reports
*.md
!README.md

# Editor settings
.vscode/
.idea/

# OS artefacts
.DS_Store
Thumbs.db
