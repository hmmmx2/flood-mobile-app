# ─────────────────────────────────────────────────────────────────────────────
# .easignore — files excluded from EAS Cloud builds
#
# EAS Build uploads only what it needs to compile the app.
# Excluding test files, docs, and local scripts speeds up upload and avoids
# accidentally leaking sensitive local dev files.
# ─────────────────────────────────────────────────────────────────────────────

# Local environment file (secrets must be set as EAS Secrets instead)
.env

# node_modules — EAS installs dependencies fresh on the build server
node_modules/

# Android native directory — upload the gradle wrapper but skip build artifacts.
# expo prebuild on EAS "reuses" the existing android/ and updates all source
# files in-place. gradle-wrapper.jar MUST be present or gradlew will fail with
# "Unable to access jarfile". We exclude only the large generated build outputs.
android/build/
android/app/build/
android/app/.cxx/
android/.gradle/
android/.idea/
android/app/debug.keystore

# Test files
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docs / reports
*.md
!README.md

# Editor settings
.vscode/
.idea/

# OS artefacts
.DS_Store
Thumbs.db
