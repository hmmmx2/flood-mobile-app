# ─────────────────────────────────────────────────────────────────────────────
# .easignore — files excluded from EAS Cloud builds
#
# EAS Build uploads only what it needs to compile the app.
# Excluding test files, docs, and local scripts speeds up upload and avoids
# accidentally leaking sensitive local dev files.
# ─────────────────────────────────────────────────────────────────────────────

# Local environment file (secrets must be set as EAS Secrets instead)
.env

# node_modules — EAS installs dependencies fresh on the build server
node_modules/

# Android native directory — excluded from the EAS archive.
# The postinstall script (scripts/ensure-debug-keystore.js) detects and removes
# any stale android/ left in the EAS workspace from a previous failed build so
# that expo prebuild always regenerates a complete fresh android/ project
# (including gradle-wrapper.jar) during the PREBUILD phase.
android/

# Test files
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docs / reports
*.md
!README.md

# Editor settings
.vscode/
.idea/

# OS artefacts
.DS_Store
Thumbs.db
