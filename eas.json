{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_API_URL": "http://10.0.2.2:4001",
        "EXPO_PUBLIC_API_BASE_URL": "http://10.0.2.2:4001",
        "EXPO_PUBLIC_CRM_API_URL":  "http://10.0.2.2:4002"
      }
    },

    "dev-cloud": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://flood-service-community-production.up.railway.app",
        "EXPO_PUBLIC_AUTH_API_URL": "https://flood-service-community-production.up.railway.app",
        "EXPO_PUBLIC_CRM_API_URL":  "https://flood-service-crm-production.up.railway.app",
        "EXPO_PUBLIC_AI_API_URL":   "https://flood-ai-prediction.up.railway.app"
      }
    },

    "kong-local": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_API_URL": "http://10.0.2.2:8080/community",
        "EXPO_PUBLIC_API_BASE_URL": "http://10.0.2.2:8080/community",
        "EXPO_PUBLIC_CRM_API_URL":  "http://10.0.2.2:8080/crm"
      }
    },

    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_AUTH_API_URL": "http://10.0.2.2:4001",
        "EXPO_PUBLIC_API_BASE_URL": "http://10.0.2.2:4001",
        "EXPO_PUBLIC_CRM_API_URL":  "http://10.0.2.2:4002",
        "EXPO_PUBLIC_AI_API_URL":   "http://10.0.2.2:8000"
      }
    },

    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://flood-service-community-production.up.railway.app",
        "EXPO_PUBLIC_AUTH_API_URL": "https://flood-service-community-production.up.railway.app",
        "EXPO_PUBLIC_CRM_API_URL":  "https://flood-service-crm-production.up.railway.app",
        "EXPO_PUBLIC_AI_API_URL":   "https://flood-ai-prediction.up.railway.app"
      }
    },

    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://flood-service-community-production.up.railway.app",
        "EXPO_PUBLIC_AUTH_API_URL": "https://flood-service-community-production.up.railway.app",
        "EXPO_PUBLIC_CRM_API_URL":  "https://flood-service-crm-production.up.railway.app",
        "EXPO_PUBLIC_AI_API_URL":   "https://flood-ai-prediction.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
